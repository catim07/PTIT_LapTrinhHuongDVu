# Lotte Mart Frontend Environment Variables
# Copy this file to .env and fill in your values

# API Backend Host (required)
VITE_API_HOST=http://localhost:3001

# Application Name
VITE_APP_NAME="Lotte Mart"

# Google OAuth Client ID (required for Google Sign-In)
# Get from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Add your domain (e.g. http://localhost:5173) to "Authorized JavaScript origins"
VITE_GOOGLE_CLIENT_ID=your_client_id_here

# Facebook App ID (optional, for Facebook login)
# Get from: https://developers.facebook.com/apps/
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here
GEMINI_API_KEY=AIzaSyBJR4HaRBSjQc52iwPFIlPNhc4uQ2Q5qN8